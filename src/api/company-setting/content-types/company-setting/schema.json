{
  "kind": "collectionType",
  "collectionName": "company_settings",
  "info": {
    "singularName": "company-setting",
    "pluralName": "company-settings",
    "displayName": "companySetting"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "companyName": {
      "type": "string"
    },
    "companyAddress": {
      "type": "text"
    },
    "email": {
      "type": "email",
      "required": true
    },
    "companyDescription": {
      "type": "text"
    },
    "companyLogo": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": false
    },
    "phoneNumber": {
      "type": "integer"
    }
  }
}
